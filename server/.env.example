# Environment Mode
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/suncity_erp
# If using MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/suncity_erp?retryWrites=true&w=majority

# Client Application URL
CLIENT_URL=http://localhost:5173

# JWT Secrets
JWT_ACCESS_SECRET=your_access_secret_key_change_in_production_to_64chars
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_to_64chars

# Field Encryption Secret (AES)
FIELD_ENCRYPT_SECRET=suncity-field-secret-32chars!!

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Nodemailer / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Twilio SMS
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_token
TWILIO_FROM=your_twilio_phone_number

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Google Drive Backup
# Download the service account json and put the base64 string here or put path to json file
GOOGLE_DRIVE_CREDENTIALS_JSON=your_base64_encoded_credentials
GOOGLE_DRIVE_FOLDER_ID=your_folder_id
