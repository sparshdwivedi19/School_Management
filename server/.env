# Environment Mode
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/suncity_erp

# Client Application URL
CLIENT_URL=http://localhost:5173

# JWT Secrets
JWT_ACCESS_SECRET=your_access_secret_key_change_in_production_to_64chars
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_to_64chars

# Field Encryption Secret (AES)
FIELD_ENCRYPT_SECRET=suncity-field-secret-32chars!!

# Cloudinary (Mock values for development)
CLOUDINARY_CLOUD_NAME=mock
CLOUDINARY_API_KEY=mock
CLOUDINARY_API_SECRET=mock
